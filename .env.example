# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: URL pública de la app en producción (Cloud Run).
# En local usa http://localhost:3000
APP_URL="http://localhost:3000"

# Firebase config — prefijo VITE_ para que Vite los exponga al frontend
# Obtén estos valores desde la consola de Firebase > Configuración del proyecto
VITE_FIREBASE_PROJECT_ID="MY_PROJECT_ID"
VITE_FIREBASE_APP_ID="MY_APP_ID"
VITE_FIREBASE_API_KEY="MY_FIREBASE_API_KEY"
VITE_FIREBASE_AUTH_DOMAIN="MY_PROJECT_ID.firebaseapp.com"
VITE_FIREBASE_STORAGE_BUCKET="MY_PROJECT_ID.firebasestorage.app"
VITE_FIREBASE_MESSAGING_SENDER_ID="MY_SENDER_ID"
VITE_FIREBASE_DATABASE_ID="MY_FIRESTORE_DATABASE_ID"
