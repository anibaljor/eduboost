{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile and settings",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "displayName": { "type": "string" },
        "grade": { "type": "string", "enum": ["Primaria", "Secundaria", "Preparatoria", "Universidad"] },
        "geminiApiKey": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email"]
    },
    "History": {
      "title": "History",
      "description": "Academic query history",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "subject": { "type": "string" },
        "grade": { "type": "string" },
        "prompt": { "type": "string" },
        "response": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "prompt", "response", "timestamp"]
    },
    "Quiz": {
      "title": "Quiz",
      "description": "Generated quizzes and results",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "title": { "type": "string" },
        "topic": { "type": "string" },
        "difficulty": { "type": "string" },
        "questions": { "type": "array" },
        "score": { "type": "number" },
        "completed": { "type": "boolean" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "title", "questions", "timestamp"]
    }
  },
  "firestore": {
    "users/{userId}": {
      "schema": "User",
      "description": "User profiles"
    },
    "users/{userId}/history/{historyId}": {
      "schema": "History",
      "description": "Academic queries for a specific user"
    },
    "users/{userId}/quizzes/{quizId}": {
      "schema": "Quiz",
      "description": "Generated quizzes for a specific user"
    }
  }
}
